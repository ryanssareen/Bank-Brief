# ============================================================
# Bank Brief — .gitignore
# ============================================================

# --- SECRETS — NEVER commit these ---
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# --- Next.js ---
.next/
out/
build/
dist/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Firebase ---
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# --- Misc ---
*.log
.vercel

# --- Local setup scripts (no need in repo) ---
setup-ssh.ps1
setup-repo.ps1
setup-project.ps1
setup-complete.ps1

# --- Word docs (keep locally, not in repo) ---
*.docx
.env*.local
